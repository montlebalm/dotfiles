" set guifont=Powerline\ Consolas:h15
" set guifont=Monaco\ for\ Powerline:h13
" set guifont=Panic\ Sans:h14
" set guifont=Source\ Code\ Pro\ for\ Powerline:h15
set guifont=Monaco:h120
